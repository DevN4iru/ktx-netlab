#!/usr/bin/env bash

HELP='
KTX i3 Core Navigation

SAFE BASICS
  Super+Enter          Open terminal
  Super+D              Open app launcher
  Super+F1             Show this help
  F1                   Show this help
  Super+P              Power menu
  Super+Shift+C        Reload i3 config
  Super+Shift+R        Restart i3

WINDOWS
  Super+Q              Hide/minimize focused window
  Super+Minus          Restore hidden window
  Super+Shift+Q        Close focused window
  Super+M              Fullscreen
  Super+Shift+Space    Toggle floating
  Super+Space          Switch tiled/floating focus

NAVIGATION
  Alt+Tab              Next window
  Alt+Shift+Tab        Previous window
  Super+Tab            Next window
  Super+Shift+Tab      Previous window
  Super+H/J/K/L        Focus left/down/up/right
  Super+Arrow          Focus by arrow keys

MOVE WINDOWS
  Super+Shift+H/J/K/L  Move window left/down/up/right
  Super+Shift+Arrow    Move window by arrow keys

WORKSPACES
  Super+1-9            Switch workspace
  Super+Shift+1-9      Move window to workspace

LAYOUT
  Super+V              Vertical split
  Super+C              Horizontal split
  Super+S              Stacking layout
  Super+T              Tabbed layout
  Super+E              Toggle split layout
  Super+R              Resize mode

KTX APPS
  Super+X              KTX Control terminal
  Super+W              Wireshark
  Super+N              Network settings
  Super+F              File manager
  Super+B              Browser

DEAD KEY POLICY
  No keybinds use = or +.

STABILITY POLICY
  Picom compositor disabled.
  Deskflow autostart disabled.
  Deskflow manual launch allowed.
  Use: ktx deskflow start
  Use: ktx deskflow stop
  True terminal transparency disabled until Xorg proves stable.

ROUTER MODE
  LOCKED. No NAT, DHCP, firewall routing, or packet forwarding is enabled.
'

if [ -n "${DISPLAY:-}" ] && command -v rofi >/dev/null 2>&1; then
  printf "%s\n" "$HELP" | rofi -dmenu -i -p "KTX i3 Help"
else
  printf "%s\n" "$HELP"
fi
