#!/usr/bin/env bash

HELP='
KTX i3 Navigation Help

BASICS
  Super+Enter          Open terminal
  Super+D              Open app launcher
  Super+/              Show this help
  Super+Esc            Power / logout menu
  Super+Shift+R        Restart i3
  Super+Shift+C        Reload i3 config

WINDOWS
  Super+Q              Hide/minimize focused window to scratchpad
  Super+Minus          Show hidden scratchpad window
  Super+Shift+Q        Close focused window
  Super+M              Fullscreen
  Super+Shift+Space    Toggle floating mode
  Super+Space          Switch tiled/floating focus

NAVIGATION
  Alt+Tab              Focus next window
  Alt+Shift+Tab        Focus previous window
  Super+Tab            Focus next window
  Super+Shift+Tab      Focus previous window
  Super+H/J/K/L        Focus left/down/up/right
  Super+Arrow          Focus by arrow keys

MOVE WINDOWS
  Super+Shift+H/J/K/L  Move window left/down/up/right
  Super+Shift+Arrow    Move window by arrow keys

WORKSPACES
  Super+1              Workspace 1:term
  Super+2              Workspace 2:web
  Super+3              Workspace 3:net
  Super+4              Workspace 4:docs
  Super+5              Workspace 5:lab
  Super+6              Workspace 6:mon
  Super+7              Workspace 7:ops
  Super+8              Workspace 8:vm
  Super+9              Workspace 9:misc
  Super+Shift+1-9      Move focused window to workspace

LAYOUT
  Super+V              Vertical split
  Super+C              Horizontal split
  Super+S              Stacking layout
  Super+T              Tabbed layout
  Super+E              Toggle split layout
  Super+R              Resize mode

KTX SHORTCUTS
  Super+X              KTX Control
  Super+W              Wireshark
  Super+N              Network Settings
  Super+F              File Manager
  Super+B              Browser

RESIZE MODE
  Super+R              Enter resize mode
  H/J/K/L or arrows    Resize
  Enter/Esc            Leave resize mode

ROUTER MODE
  LOCKED. No NAT, DHCP, firewall routing, or packet forwarding is enabled.
'

if [ -n "${DISPLAY:-}" ] && command -v rofi >/dev/null 2>&1; then
  printf "%s\n" "$HELP" | rofi -dmenu -i -p "KTX i3 Help"
else
  printf "%s\n" "$HELP"
fi
