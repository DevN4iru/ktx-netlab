#!/usr/bin/env bash
cat <<'BANNER'
KTX NetLab OS v0.1
Welcome back, Kirch.
Setting up the KTX NetLab. Please wait a moment.
BANNER

echo
echo "Host:   $(hostname)"
echo "Kernel: $(uname -r)"
echo "Mode:   $(cat /etc/ktx-mode 2>/dev/null || echo lab)"
echo
ip -br addr | sed 's/^/  /'
echo
echo "Run: ktx help"
